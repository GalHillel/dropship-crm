{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@dropship/types": ["./packages/types/src/index.ts"],
      "@dropship/database": ["./packages/database/src/index.ts"],
      "@dropship/ui": ["./packages/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}
